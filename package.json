{
  "name": "bluetooth-connector-desktop",
  "version": "1.0.0",
  "description": "Bluetooth Connector - Sync audio/video across multiple devices. Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux",
    "build-mac": "electron-builder --mac",
    "build-all": "electron-builder --win --linux --mac",
    "dist": "electron-builder --publish never"
  },
  "author": "Zawadi Sanga",
  "license": "MIT",
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.zass.bluetoothconnector",
    "productName": "Bluetooth Connector",
    "copyright": "Copyright © 2024 Zawadi Sanga",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.ico",
      "icon.png",
      "icon.icns"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bluetooth Connector"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "icon.png",
      "category": "AudioVideo",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns",
      "category": "public.app-category.music",
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}

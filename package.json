{
  "name": "bluetooth-connector-web",
  "version": "1.0.0",
  "description": "Web app + PWA",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.5.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  }
}


{
  "name": "bluetooth-connector-desktop",
  "version": "1.0.0",
  "description": "Desktop client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --publish never"
  },
  "author": {
    "name": "Zawadi Sanga",
    "email": "zawadi@example.com"
  },
  "homepage": "https://bluetooth.zass.website",
  "build": {
    "appId": "com.zass.bluetoothconnector",
    "productName": "Bluetooth Connector",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo",
      "maintainer": "Zawadi Sanga <zawadi@example.com>"
    }
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  }
}

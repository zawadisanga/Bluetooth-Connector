{
  "name": "bluetooth-connector",
  "version": "1.0.0",
  "description": "Connect multiple devices to one source - listen together globally!",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "heroku-postbuild": "echo 'Build completed'"
  },
  "engines": {
    "node": "16.x",
    "npm": "8.x"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.5.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  },
  "keywords": [
    "bluetooth",
    "connector",
    "audio",
    "sync",
    "streaming"
  ],
  "author": "Your Name",
  "license": "MIT"
}


{
  "name": "bluetooth-connector-desktop",
  "version": "1.0.0",
  "description": "Bluetooth Connector Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.zass.bluetoothconnector",
    "productName": "Bluetooth Connector",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    }
  }
}
